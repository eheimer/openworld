{
  "compilerOptions": {
    "target": "ES2023",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "outDir": "./dist/server",
    "rootDir": "./server",
    "declaration": true,
    "removeComments": true,
    "incremental": false,
    "sourceMap": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["server/**/*"],
  "exclude": ["client", "**/*.spec.ts"]
}
